#include <iostream>
using namespace std;
int main (){
    int arr[5];
    int sum = 0;
    cout <<"Enter 5 numbers" <<"\n";
    
    for(int i = 0; i < 5; i++){
        cin >> arr[i];
        sum = sum + arr[i];
    }
    cout << "sum of array  elements are..." << sum ;
}
    
